# ============================================================
# Plantilla de variables de entorno (referencia)
# GitHub Pages no soporta variables de entorno reales en runtime:
# los valores equivalentes se configuran directamente en
# assets/js/config.js (el anon key es seguro para exponer,
# está protegido por RLS). Este archivo es solo documentación.
# ============================================================

SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...

# NUNCA uses esto en frontend/GitHub Pages:
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
